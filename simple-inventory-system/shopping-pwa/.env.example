# Einkaufs-PWA — Build-Konfiguration (VITE_*, zur Build-Zeit eingebettet)

# Inventar-Backend (REST + WebSocket)
VITE_API_URL=https://inventar.fwv-raura.ch/api
VITE_WS_URL=wss://inventar.fwv-raura.ch/ws

# Authentik OIDC (bestehende App "inventory-system")
VITE_AUTHENTIK_URL=https://auth.fwv-raura.ch
VITE_AUTHENTIK_CLIENT_ID=inventory-system

# WICHTIG (Deploy): Die Redirect-URI  https://einkauf.fwv-raura.ch/auth/callback
# muss in der Authentik-App "inventory-system" als erlaubte Redirect-URI ergänzt werden.
