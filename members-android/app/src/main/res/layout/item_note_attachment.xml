<?xml version="1.0" encoding="utf-8"?>
<!-- Ein Anhang einer Notiz: Vorschau (Bild) bzw. Datei-Icon (Dokument),
     Dateiname + Meta, und ein Entfernen-Knopf. Die ganze Zeile ist antippbar
     zum Oeffnen. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/attRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/attThumb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@color/divider"
        android:contentDescription="Anhang"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_file" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/attName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/attMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/attRemove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Anhang entfernen"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/text_secondary" />

</LinearLayout>
