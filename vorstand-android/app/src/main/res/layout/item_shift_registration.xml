<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="6dp"
    android:gravity="center_vertical">

    <!-- Name + Zusatzdaten (Personenzahl, Telefon, Begleitung, Allergien ...)
         in einer vertikalen Spalte, damit die Details unter dem Namen stehen -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/regName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <!-- Mehrzeilige Detailzeile; wird per Code ein-/ausgeblendet -->
        <TextView
            android:id="@+id/regDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/regStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingEnd="4dp" />

    <!-- Alternative Schicht vorschlagen: nur fuer Schicht-Anmeldungen sichtbar
         (vom Adapter aktiviert), bei direkten Anmeldungen bleibt der Button aus -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAlternative"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="⇄"
        android:textColor="@color/on_primary"
        android:textSize="16sp"
        android:backgroundTint="@color/warning"
        android:layout_marginEnd="4dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEdit"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="✎"
        android:textColor="@color/on_primary"
        android:textSize="14sp"
        android:backgroundTint="@color/info"
        android:layout_marginEnd="4dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApprove"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="✓"
        android:textColor="@color/on_primary"
        android:textSize="16sp"
        android:backgroundTint="@color/success"
        android:layout_marginEnd="4dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReject"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="✗"
        android:textColor="@color/on_primary"
        android:textSize="16sp"
        android:backgroundTint="@color/error"
        android:visibility="gone" />
</LinearLayout>
